# Maintainer: Rafal Brzegowy <rafal.brzegowy@yahoo.com>

_realname=calculix
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=2.17
pkgrel=1
pkgdesc='Library of Iterative Solvers for linear systems (mingw-w64)'
arch=('any')
options=('!docs')
license=('BSD')
url='https://www.ssisc.org/lis/'
source=(https://github.com/msys2/MINGW-packages/files/5173055/CalculiX.zip)
sha256sums=('SKIP')

build() {
  cd ${srcdir}/CalculiX/ccx_2.17/src
  make -f Makefile_mingw_i8
}

package() {
  cd "${srcdir}/build-${MINGW_CHOST}"
  make install DESTDIR="${pkgdir}"
  install -Dm644 ${srcdir}/${_realname}-${pkgver}/COPYING ${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE
}

